# Salin file ini menjadi .env dan isi dengan nilai yang sebenarnya
# JANGAN commit file .env ke GitHub!

GEMINI_API_KEY=your_gemini_api_key_here

# Path model Whisper (sesuaikan dengan path di komputer kamu)
WHISPER_MODEL_PATH=models/whisper.cpp/models/ggml-large-v3-turbo.bin
# Alternatif model lebih ringan jika RAM terbatas:
# WHISPER_MODEL_PATH=models/whisper.cpp/models/ggml-base.bin

# Path Whisper executable
WHISPER_EXEC_PATH=models/whisper.cpp/build/bin/whisper-cli

# Path model Coqui TTS
TTS_MODEL_PATH=app/coqui_tts/config.json
TTS_CHECKPOINT_PATH=app/coqui_tts/checkpoint_100000.pth
TTS_SPEAKERS_PATH=app/coqui_tts/speakers.pth

# Mode default sistem: preserve | normalize | translate
DEFAULT_MODE=preserve
